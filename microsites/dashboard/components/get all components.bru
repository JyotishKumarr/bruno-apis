meta {
  name: get all components
  type: http
  seq: 3
}

get {
  url: http://localhost:3000/microsites/dashboard/components?start=0&limit=3&search=image
  body: none
  auth: bearer
}

params:query {
  start: 0
  limit: 3
  search: image
}

auth:bearer {
  token: {{authToken}}
}

settings {
  encodeUrl: true
}
